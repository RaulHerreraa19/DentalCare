generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// 1. Core de Tenancy y Estructura Organizacional
// ----------------------------------------------------------------------

enum PlanType {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  OWNER
  DOCTOR
  RECEPTIONIST
}

enum Status {
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
}

model Organization {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  plan           PlanType  @default(BASIC)
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  logo_url       String?   // Logo institucional por defecto

  clinics        Clinic[]
  users          User[]
  patients       Patient[]
  cash_registers CashRegister[]
  consents       Consent[]
  whatsapp_config OrganizationWhatsAppConfig?

  @@map("organizations")
}

model OrganizationWhatsAppConfig {
  id                   String       @id @default(uuid())
  organization_id      String       @unique
  enabled              Boolean      @default(false)
  dry_run              Boolean      @default(true)
  access_token         String?
  phone_number_id      String?
  api_version          String       @default("v21.0")
  template_name        String       @default("appointment_confirmation_24h")
  template_lang        String       @default("es_MX")
  webhook_verify_token String?
  reminders_enabled    Boolean      @default(false)
  job_interval_ms      Int          @default(300000)
  window_minutes       Int          @default(15)
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  organization         Organization @relation(fields: [organization_id], references: [id])

  @@map("organization_whatsapp_configs")
}

model Clinic {
  id              String       @id @default(uuid())
  organization_id String
  name            String
  address         String?
  phone           String?
  status          Status       @default(PENDING_PAYMENT)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  logo_url        String?      // Logo específico de la sucursal

  organization    Organization @relation(fields: [organization_id], references: [id])
  offices         Office[]
  user_assignments UserClinicAssignment[]
  appointments    Appointment[]
  doctor_schedules DoctorSchedule[]
  cash_registers  CashRegister[]

  @@map("clinics")
}

model Office {
  id          String   @id @default(uuid())
  clinic_id   String
  name        String
  floor       String?
  status      Status   @default(PENDING_PAYMENT)

  clinic      Clinic   @relation(fields: [clinic_id], references: [id])
  appointments Appointment[]
  user_assignments UserOfficeAssignment[]

  @@map("offices")
}

model User {
  id              String    @id @default(uuid())
  organization_id String?   // Null para SUPER_ADMIN
  supervisor_id   String?
  email           String    @unique
  password_hash   String
  first_name      String
  last_name       String
  phone           String?
  role            Role
  license_number  String?   // Cédula Profesional (Mandatorio para firma)
  specialty       String?   // Especialidad
  signature_stamp_url String? // Imagen de firma autógrafa
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization    Organization? @relation(fields: [organization_id], references: [id])
  supervisor      User?         @relation("UserSupervisor", fields: [supervisor_id], references: [id])
  subordinates    User[]        @relation("UserSupervisor")
  clinic_assignments UserClinicAssignment[]
  office_assignments UserOfficeAssignment[]
  
  appointments_created Appointment[] @relation("AppointmentCreator")
  appointments_as_doctor Appointment[] @relation("AppointmentDoctor")
  
  services_offered  Service[]
  
  medical_records   MedicalRecord[] @relation("DoctorTreating")
  medical_record_versions_created MedicalRecordVersion[]
  medical_notes_authored MedicalNote[] @relation("MedicalNoteAuthor")
  medical_note_versions_created MedicalNoteVersion[]
  odontograms_created Odontogram[] @relation("OdontogramCreator")
  consents_accepted  Consent[] @relation("ConsentAcceptedBy")
  doctor_schedules  DoctorSchedule[]
  cash_registered   CashRegister[]
  audit_logs        AuditLog[]
  prescriptions     Prescription[]

  @@map("users")
}

model UserClinicAssignment {
  id        String @id @default(uuid())
  user_id   String
  clinic_id String

  user      User   @relation(fields: [user_id], references: [id])
  clinic    Clinic @relation(fields: [clinic_id], references: [id])

  @@unique([user_id, clinic_id])
  @@map("user_clinic_assignments")
}

model UserOfficeAssignment {
  id        String @id @default(uuid())
  user_id   String
  office_id String

  user      User   @relation(fields: [user_id], references: [id])
  office    Office @relation(fields: [office_id], references: [id])

  @@unique([user_id, office_id])
  @@map("user_office_assignments")
}

// ----------------------------------------------------------------------
// 2. Pacientes, Citas y Servicios
// ----------------------------------------------------------------------

enum Gender {
  M
  F
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

model Patient {
  id                String    @id @default(uuid())
  organization_id   String
  first_name        String
  last_name         String
  email             String?
  phone             String    // Usado para WhatsApp
  date_of_birth     DateTime?
  gender            Gender?
  address           String?
  emergency_contact String?
  notes             String?   // Notas administrativas, no clínicas
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  organization      Organization @relation(fields: [organization_id], references: [id])
  appointments      Appointment[]
  medical_records   MedicalRecord[]
  prescriptions     Prescription[]
  consents          Consent[]

  @@map("patients")
}

model Service {
  id              String   @id @default(uuid())
  doctor_id       String
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  doctor          User     @relation(fields: [doctor_id], references: [id])
  appointment_services AppointmentService[]

  @@map("services")
}

model Appointment {
  id              String            @id @default(uuid())
  organization_id String
  clinic_id       String
  office_id       String
  doctor_id       String
  patient_id      String
  created_by      String
  
  start_time      DateTime
  end_time        DateTime
  status          AppointmentStatus @default(PENDING)
  reason          String?
  cancel_reason   String?
  
  total_amount    Decimal           @db.Decimal(10, 2) @default(0)
  is_paid         Boolean           @default(false)
  
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  clinic          Clinic            @relation(fields: [clinic_id], references: [id])
  office          Office            @relation(fields: [office_id], references: [id])
  doctor          User              @relation("AppointmentDoctor", fields: [doctor_id], references: [id])
  patient         Patient           @relation(fields: [patient_id], references: [id])
  creator         User              @relation("AppointmentCreator", fields: [created_by], references: [id])
  
  services        AppointmentService[]
  medical_notes   MedicalNote[]
  prescriptions   Prescription[]
  cash_registers  CashRegister[]
  reminders       AppointmentReminder[]

  @@map("appointments")
}

model AppointmentReminder {
  id                  String         @id @default(uuid())
  appointment_id      String
  reminder_type       String         @default("WHATSAPP_CONFIRM_24H")
  scheduled_for       DateTime
  sent_at             DateTime?
  status              ReminderStatus @default(PENDING)
  retry_count         Int            @default(0)
  last_error          String?
  provider_message_id String?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  appointment         Appointment    @relation(fields: [appointment_id], references: [id])

  @@unique([appointment_id, reminder_type])
  @@map("appointment_reminders")
}

model AppointmentService {
  id              String      @id @default(uuid())
  appointment_id  String
  service_id      String?     // Opcional por si agregamos items manuales no en catálogo
  name            String      // Guardamos nombre del servicio (snapshot por si cambia)
  price           Decimal     @db.Decimal(10, 2) // Precio cobrado (snapshot)

  appointment     Appointment @relation(fields: [appointment_id], references: [id])
  service         Service?    @relation(fields: [service_id], references: [id])

  @@map("appointment_services")
}

// ----------------------------------------------------------------------
// 3. Expediente Médico
// ----------------------------------------------------------------------

enum NoteType {
  CONSULTATION
  FOLLOW_UP
  PROCEDURE
  PRESCRIPTION
}

enum RecordStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ConsentType {
  DATA_PRIVACY
  DENTAL_TREATMENT
  WHATSAPP
}

enum ConsentSignatureType {
  DRAWN
  CLICK_WRAP
  OTP
  ELECTRONIC_SIGNATURE
}

model MedicalRecord {
  id                String       @id @default(uuid())
  patient_id        String
  doctor_id         String       // Médico tratante. Privacidad: solo él consulta este exp.
  organization_id   String?
  status            RecordStatus @default(DRAFT)
  current_version   Int          @default(1)
  locked_at         DateTime?
  signed_at         DateTime?
  signature_hash    String?
  
  diagnosis               String?
  treatment_plan          String?
  
  // Historia Clínica Estructurada
  family_history          String?   @db.Text
  pathological_history    String?   @db.Text
  non_pathological_history String?  @db.Text
  allergies               String?   @db.Text
  surgeries               String?   @db.Text
  current_medications     String?   @db.Text
  
  // Específicos de Odontología
  dental_history          String?   @db.Text
  brushing_frequency      String?
  use_floss               Boolean?  @default(false)
  
  clinical_notes          Json?        // Notas adicionales flexibles
  medications             Json?        // Snapshot de recetas (opcional)
  
  created_at              DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  patient           Patient      @relation(fields: [patient_id], references: [id])
  doctor            User         @relation("DoctorTreating", fields: [doctor_id], references: [id])
  
  versions          MedicalRecordVersion[]
  notes             MedicalNote[]
  odontograms       Odontogram[]

  @@unique([patient_id, doctor_id])
  @@map("medical_records")
}

model MedicalRecordVersion {
  id                String       @id @default(uuid())
  medical_record_id  String
  version_number     Int
  created_by         String
  change_reason      String?
  sections           Json
  is_locked          Boolean      @default(false)
  signed_at          DateTime?
  signature_hash     String?
  created_at         DateTime     @default(now())

  medical_record     MedicalRecord @relation(fields: [medical_record_id], references: [id])
  creator            User          @relation(fields: [created_by], references: [id])

  @@unique([medical_record_id, version_number])
  @@map("medical_record_versions")
}

model MedicalNote {
  id                String        @id @default(uuid())
  medical_record_id String
  appointment_id    String?
  author_id         String
  version           Int           @default(1)
  content           String
  note_type         NoteType      @default(CONSULTATION)
  attachments       Json?         // Rutas a imagenes/archivos
  is_signed         Boolean       @default(false)
  signed_at         DateTime?
  signature_hash    String?       // SHA-256
  locked_at         DateTime?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  medical_record    MedicalRecord @relation(fields: [medical_record_id], references: [id])
  appointment       Appointment?  @relation(fields: [appointment_id], references: [id])
  author            User          @relation("MedicalNoteAuthor", fields: [author_id], references: [id])
  versions          MedicalNoteVersion[]

  @@map("medical_notes")
}

model MedicalNoteVersion {
  id                String        @id @default(uuid())
  medical_note_id   String
  version_number    Int
  created_by        String
  content           String
  note_type         NoteType      @default(CONSULTATION)
  attachments       Json?
  is_signed         Boolean       @default(false)
  signed_at         DateTime?
  signature_hash    String?
  change_reason     String?
  created_at        DateTime      @default(now())

  medical_note      MedicalNote   @relation(fields: [medical_note_id], references: [id])
  creator           User          @relation(fields: [created_by], references: [id])

  @@unique([medical_note_id, version_number])
  @@map("medical_note_versions")
}

model Odontogram {
  id                String        @id @default(uuid())
  medical_record_id String
  created_by        String
  tooth_data        Json          // { toothNumber: { status: "CARIES", surfaces: ["M", "O"], notes: "..." } }
  version           Int           @default(1)
  status            RecordStatus  @default(DRAFT)
  is_locked         Boolean       @default(false)
  signed_at         DateTime?
  signature_hash    String?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  medical_record    MedicalRecord @relation(fields: [medical_record_id], references: [id])
  creator           User          @relation("OdontogramCreator", fields: [created_by], references: [id])

  @@map("odontograms")
}

model Consent {
  id                String                @id @default(uuid())
  organization_id   String
  patient_id        String
  consent_type      ConsentType
  title             String
  content           String                @db.Text
  version           Int                   @default(1)
  language          String                @default("es_MX")
  accepted          Boolean               @default(false)
  accepted_at       DateTime?
  accepted_by       String?
  signature_type    ConsentSignatureType?
  document_hash     String?
  ip_address        String?
  user_agent        String?
  revoked_at        DateTime?
  revoked_reason    String?
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt

  organization      Organization          @relation(fields: [organization_id], references: [id])
  patient           Patient               @relation(fields: [patient_id], references: [id])
  accepted_by_user  User?                 @relation("ConsentAcceptedBy", fields: [accepted_by], references: [id])

  @@unique([patient_id, consent_type, version])
  @@map("consents")
}

// ----------------------------------------------------------------------
// 4. Operación y Horarios
// ----------------------------------------------------------------------

model DoctorSchedule {
  id          String   @id @default(uuid())
  doctor_id   String
  clinic_id   String
  day_of_week Int      // 0 = Sunday, ..., 6 = Saturday
  start_time  String   // e.g., "09:00"
  end_time    String   // e.g., "17:00"
  is_active   Boolean  @default(true)

  doctor      User     @relation(fields: [doctor_id], references: [id])
  clinic      Clinic   @relation(fields: [clinic_id], references: [id])

  @@map("doctor_schedules")
}

enum CashType {
  INCOME
  EXPENSE
}

enum CashCategory {
  APPOINTMENT_PAYMENT
  SUPPLIES
  RENT
  SALARY
  OTHER
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

model CashRegister {
  id              String        @id @default(uuid())
  organization_id String
  clinic_id       String
  appointment_id  String?
  type            CashType
  amount          Decimal       @db.Decimal(10, 2)
  description     String
  category        CashCategory  @default(OTHER)
  payment_method  PaymentMethod?
  registered_by   String
  created_at      DateTime      @default(now())

  organization    Organization  @relation(fields: [organization_id], references: [id])
  clinic          Clinic        @relation(fields: [clinic_id], references: [id])
  appointment     Appointment?  @relation(fields: [appointment_id], references: [id])
  user            User          @relation(fields: [registered_by], references: [id])

  @@map("cash_registers")
}

model AuditLog {
  id              String   @id @default(uuid())
  user_id         String?
  action          String   // CREATE, SIGN, UPDATE, DELETE, VIEW
  target_model    String?  // MEDICAL_RECORD, PATIENT, etc.
  target_id       String?
  organization_id String?
  patient_id      String?
  resource_type   String?
  resource_id     String?
  access_granted  Boolean?
  ip_address      String?
  user_agent      String?
  before_snapshot Json?
  after_snapshot  Json?
  reason          String?
  metadata        Json?    // { ip: "...", old_value: "...", new_value: "..." }
  created_at      DateTime @default(now())

  user            User?    @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model Prescription {
  id              String   @id @default(uuid())
  patient_id      String
  doctor_id       String
  appointment_id  String?
  medications     Json     // [{ name, dose, frequency, duration }]
  instructions    String?
  created_at      DateTime @default(now())

  patient         Patient  @relation(fields: [patient_id], references: [id])
  doctor          User     @relation(fields: [doctor_id], references: [id])
  appointment     Appointment? @relation(fields: [appointment_id], references: [id])

  @@map("prescriptions")
}
